3. Function to Check Even or Odd
def check(num):
    if num % 2 == 0:
        return "Even"
    else:
        return "Odd"

print(check(7))

Output
Odd

4. Function to Find Largest Number
def largest(a, b):
    if a > b:
        return a
    else:
        return b

print(largest(10, 20))

Output
20

5. Function to Find Factorial
def factorial(n):
    fact = 1
    for i in range(1, n+1):
        fact = fact * i
    return fact

print(factorial(5))

Output
120

