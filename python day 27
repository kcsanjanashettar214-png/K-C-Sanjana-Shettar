    <input type="text" name="task" placeholder="Enter task" required>
    <input type="submit" value="Add Task">
</form>

<h3>Your Tasks:</h3>

<ul>
{% for t in tasks %}
    <li>{{ t }}</li>
{% endfor %}
</ul>

</body>
</html>

